      <guid>http://localhost:1313/docs/anglais/vocabulaire/idiomes/various/</guid>
      <description>&lt;h2 id=&#34;idiomes-anglais-courants&#34;&gt;Idiomes anglais courants&lt;a class=&#34;anchor&#34; href=&#34;#idiomes-anglais-courants&#34;&gt;#&lt;/a&gt;&lt;/h2&gt;&#xA;&lt;p&gt;lorem ipsum&lt;/p&gt;&#xA;&lt;div class=&#34;center&#34;&gt;&#xD;&#xA;&lt;p&gt;&lt;em&gt;Cliquez sur chaque idiome pour voir sa signification et des exemples&lt;/em&gt;&lt;/p&gt;&#xA;&lt;/div&gt;&#xD;&#xA;&lt;h3 id=&#34;divers&#34;&gt;Divers&lt;a class=&#34;anchor&#34; href=&#34;#divers&#34;&gt;#&lt;/a&gt;&lt;/h3&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th&gt;Idiome&lt;/th&gt;&#xA;          &lt;th&gt;Signification&lt;/th&gt;&#xA;          &lt;th&gt;Exemple concret&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Break the bank&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Ruiner financièrement&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;Don&amp;rsquo;t worry, dinner won&amp;rsquo;t break the bank.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;A picture is worth a thousand words&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Coûter très cher&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;University education costs an arm and a leg.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;It takes two to tango&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Practice makes perfect&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;To bite more than you can chew&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;To beat around the bush&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Actions speak louder than words&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Taste of your own medicine&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;Speak of the devil&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;The grass is greener&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;A blessing in disguise&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;To be in the same boat&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;to be in the spotlight&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;add insult to injury&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td&gt;&lt;strong&gt;give it your best shot&lt;/strong&gt;&lt;/td&gt;&#xA;          &lt;td&gt;Payer le prix fort&lt;/td&gt;&#xA;          &lt;td&gt;&amp;ldquo;We paid through the nose for those concert tickets.&amp;rdquo;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;</description>
