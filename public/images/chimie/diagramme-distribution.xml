  <path d="M 40,20 Q 120,20 180,60 T 240,140 T 317,180 T 394,260 T 480,320 T 560,340" class="curve-acid"/>
  
  <!-- Courbe de la base A- (bleue) -->
  <path d="M 40,340 Q 120,340 180,280 T 240,200 T 317,180 T 394,80 T 480,30 T 560,20" class="curve-base"/>
  
  <!-- Légendes -->
  <text x="100" y="50" class="label" fill="#d32f2f" font-weight="bold">Acide (HA)</text>
  <text x="450" y="50" class="label" fill="#1976d2" font-weight="bold">Base (A⁻)</text>
  
  <!-- Labels des axes -->
  <text x="300" y="390" class="label" text-anchor="middle" font-weight="bold">pH</text>
  <text x="15" y="200" class="label" writing-mode="tb" font-weight="bold">Proportion (%)</text>
